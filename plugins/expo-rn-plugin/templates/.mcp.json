{
  "mcpServers": {
    "database": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": [
        "__NODE_PATH__",
        "__MCPS_DIR__/database-mcp-server/dist/index.js"
      ]
    },
    "expo": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": [
        "__NODE_PATH__",
        "__MCPS_DIR__/expo-mcp-server/dist/index.js"
      ]
    },
    "sentry": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": [
        "npx",
        "-y",
        "@sentry/mcp-server@latest",
        "--organization-slug=${SENTRY_ORG}"
      ]
    },
    "stripe": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": ["npx", "-y", "@stripe/mcp", "--tools=all"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "github": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": ["npx", "-y", "@modelcontextprotocol/server-github"]
    },
    "figma": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": ["npx", "-y", "figma-developer-mcp", "--stdio"]
    },
    "doppler": {
      "type": "stdio",
      "command": "./scripts/mcp-run.sh",
      "args": ["npx", "-y", "@dopplerhq/mcp-server"]
    },
    "firebase": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "experimental:mcp"]
    }
  }
}
